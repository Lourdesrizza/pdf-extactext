@startuml

skinparam Sequence {
    BackgroundColor #FFF0F5
    BorderColor #FF69B4
    FontColor #4A4A4A
    ArrowColor #FF69B4
    LifeLineBorderColor #FFB6C1
    LifeLineBackgroundColor #FAFAFA
    ParticipantBorderColor #FF69B4
    ParticipantBackgroundColor #FFE4E1
    BoxBackgroundColor #FAFAFA
    BoxBorderColor #FF69B4
    GroupBackgroundColor #FFF0F5
    GroupBorderColor #FFB6C1
}
skinparam shadowing false
skinparam defaultFontName "Segoe UI"

skinparam note {
    BackgroundColor #FFF0F5
    BorderColor #FF69B4
    FontColor #4A4A4A
}

skinparam participant {
    BackgroundColor #FFE4E1
    BorderColor #FF69B4
    FontColor #4A4A4A
}

skinparam actor {
    BackgroundColor #FFC0CB
    BorderColor #FF69B4
    FontColor #4A4A4A
}

skinparam database {
    BackgroundColor #FFF0F5
    BorderColor #FF69B4
    FontColor #4A4A4A
}

title Diagrama de Secuencia - PDFExtractex (Vista Simplificada)

' ================================================================
' ACTORES PRINCIPALES
' ================================================================

box "1. Capa de Presentación" #FFFFFF
    actor "Cliente" as Cliente
    participant "R1: PDFRouter" as PDFRouter
    participant "R2: UserRouter" as UserRouter
end box

box "2. Capa de Aplicación" #FFFFFF
    participant "S1: PDFService" as PDFServ
    participant "S2: UserService" as UserServ
end box

box "3. Capa de Dominio" #FFFFFF
    database "Librería PDF" as LibPDF
end box

box "4. Infraestructura" #FFFFFF
    database "MongoDB" as MongoDB
end box

' ================================================================
' ESCENARIO 1: SUBIR Y PROCESAR PDF
' ================================================================

== Escenario 1: Subir y Procesar PDF ==

Cliente -> PDFRouter : POST /upload (archivo PDF)
activate PDFRouter

    PDFRouter -> PDFServ : extract_text(contenido)
    activate PDFServ

        PDFServ -> LibPDF : procesar documento
        activate LibPDF
            LibPDF --> PDFServ : texto extraído
        deactivate LibPDF

        PDFServ --> PDFRouter : texto (str)
    deactivate PDFServ

    alt Texto extraído exitosamente
        PDFRouter --> Cliente : HTTP 200 OK + JSONResponse
    else Archivo no válido o PDF sin texto
        PDFRouter --> Cliente : HTTP 400 Bad Request
    end

deactivate PDFRouter

' ================================================================
' ESCENARIO 2: CREAR USUARIO
' ================================================================

== Escenario 2: Crear Usuario (POST /users) ==

Cliente -> UserRouter : POST /users (datos)
activate UserRouter

    UserRouter -> UserServ : create_user(request)
    activate UserServ

        alt Email ya registrado
            UserServ --> UserRouter : ValidationException
            UserRouter --> Cliente : HTTP 400 Bad Request
        else Email válido

            UserServ -> MongoDB : insert(documento)
            activate MongoDB
                MongoDB --> UserServ : ID generado
            deactivate MongoDB

            UserServ --> UserRouter : UserResponse
        end

    deactivate UserServ

    UserRouter --> Cliente : HTTP 201 Created + UserResponse
    deactivate UserRouter

' ================================================================
' ESCENARIO 3: OBTENER USUARIO POR ID
' ================================================================

== Escenario 3: Obtener Usuario por ID (GET /users/{id}) ==

Cliente -> UserRouter : GET /users/{id}
activate UserRouter

    UserRouter -> UserServ : get_user_by_id(id)
    activate UserServ

        UserServ -> MongoDB : find_by_id(id)
        activate MongoDB

            alt Usuario no encontrado
                MongoDB --> UserServ : null
                UserServ --> UserRouter : NotFoundException
                UserRouter --> Cliente : HTTP 404 Not Found
            else Usuario encontrado
                MongoDB --> UserServ : documento
            end

        deactivate MongoDB

        UserServ --> UserRouter : UserResponse
    deactivate UserServ

    UserRouter --> Cliente : HTTP 200 OK + UserResponse
deactivate UserRouter

@enduml
